@model IEnumerable<TiendaCosmeticos.Models.Categoria>

<div class="container my-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="font-elegant" style="font-size: 1.6rem;"><i class="bi bi-tags me-2" style="color: var(--rose-gold);"></i>Gestión de Categorías</h2>
        <a asp-action="Create" class="btn btn-chelya"><i class="bi bi-plus-circle me-1"></i> Nueva Categoría</a>
    </div>

    <table class="tabla-chelya">
        <thead>
            <tr>
                <th>ID</th>
                <th>Nombre</th>
                <th>Descripción</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var cat in Model)
            {
                <tr>
                    <td>@cat.Id</td>
                    <td class="fw-semibold">@cat.Nombre</td>
                    <td class="text-muted">@cat.Descripcion</td>
                    <td>
                        @if (cat.Activo)
                        {
                            <span class="badge-chelya badge-chelya-success">Visible</span>
                        }
                        else
                        {
                            <span class="badge-chelya badge-chelya-secondary">Oculta</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@cat.Id" class="btn btn-chelya-outline btn-chelya-sm"><i class="bi bi-pencil me-1"></i>Editar</a>
                        @if (cat.Activo)
                        {
                            <form asp-action="Desactivar" asp-route-id="@cat.Id" method="post" class="d-inline m-0">
                                <button type="submit" class="btn btn-chelya-outline btn-chelya-sm ms-1" style="border-color: #F5C6CB; color: #721C24;"><i class="bi bi-eye-slash me-1"></i>Ocultar</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
