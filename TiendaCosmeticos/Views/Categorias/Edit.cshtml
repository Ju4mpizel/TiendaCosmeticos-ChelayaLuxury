@model TiendaCosmeticos.Models.Categoria

<div class="container my-4" style="max-width: 500px;">
    <div class="card-elegant p-4">
        <h2 class="font-elegant mb-4"><i class="bi bi-pencil-square me-2" style="color: var(--rose-gold);"></i> Editar Categoría</h2>
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="mb-3">
                <label asp-for="Nombre">Nombre de la Categoría</label>
                <input asp-for="Nombre" class="form-control form-chelya" placeholder="Ej: Labiales" required />
            </div>
            <div class="mb-3 form-check form-switch">
                <input asp-for="Activo" class="form-check-input" type="checkbox" id="switchCat">
                <label class="form-check-label text-muted" for="switchCat">Categoría Activa</label>
            </div>
            <div class="d-flex justify-content-between mt-4">
                <a href="/Categorias/Index" class="btn btn-chelya-outline"><i class="bi bi-arrow-left me-1"></i>Cancelar</a>
                <button type="submit" class="btn btn-chelya px-4"><i class="bi bi-check-lg me-1"></i>Guardar Cambios</button>
            </div>
        </form>
    </div>
</div>
