@model TiendaCosmeticos.Models.Categoria

<div class="container my-4" style="max-width: 500px;">
    <div class="card-elegant p-4">
        <h3 class="font-elegant mb-4 text-center"><i class="bi bi-plus-circle me-2" style="color: var(--rose-gold);"></i> Crear Categoría</h3>

        <form asp-action="Create" method="post">
            <div class="mb-3">
                <label>Nombre de la Categoría</label>
                <input asp-for="Nombre" class="form-control form-chelya" placeholder="Ej: Labiales, Perfumes" required />
            </div>
            <div class="mb-4">
                <label>Descripción</label>
                <textarea asp-for="Descripcion" class="form-control form-chelya" rows="3" placeholder="Breve detalle..."></textarea>
            </div>

            <div class="d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-chelya-outline"><i class="bi bi-arrow-left me-1"></i>Volver</a>
                <button type="submit" class="btn btn-chelya"><i class="bi bi-check-lg me-1"></i>Guardar</button>
            </div>
        </form>
    </div>
</div>
