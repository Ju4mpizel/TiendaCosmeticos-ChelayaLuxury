@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Chelaya Luxury</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-chelya">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    CHELAYA LUXURY
                </a>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index"><i class="bi bi-shop"></i> Inicio</a>
                        </li>

                        @if (Context.Session.GetString("UsuarioRol") == "Administrador")
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-danger" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-gear-fill admin-nav-icon"></i> Panel Admin
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="adminDropdown">
                                    <li><a class="dropdown-item" asp-controller="Categorias" asp-action="Index"><i class="bi bi-tags"></i>Categorías</a></li>
                                    <li><a class="dropdown-item" asp-controller="Productos" asp-action="Index"><i class="bi bi-box-seam"></i>Productos</a></li>
                                    <li><a class="dropdown-item" asp-controller="Usuarios" asp-action="Index"><i class="bi bi-people"></i>Usuarios</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-controller="Pedido" asp-action="Index"><i class="bi bi-journal-text"></i>Ver Pedidos</a></li>
                                    <li><a class="dropdown-item" asp-controller="Pago" asp-action="Index"><i class="bi bi-credit-card"></i>Historial de Pagos</a></li>
                                </ul>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav align-items-center">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Carrito" asp-action="Index"><i class="bi bi-bag"></i> Carrito</a>
                        </li>

                        @if (Context.Session.GetInt32("UsuarioId") != null)
                        {
                            <li class="nav-item d-flex align-items-center gap-2">
                                <span class="nav-link text-muted small pe-0"><i class="bi bi-person-circle me-1"></i>@Context.Session.GetString("UsuarioNombre")</span>
                                <a class="btn btn-outline-chelya btn-sm" asp-controller="Login" asp-action="Salir">Salir</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Login" asp-action="Index"><i class="bi bi-box-arrow-in-right"></i> Iniciar Sesión</a>
                            </li>
                            <li class="nav-item ms-2">
                                <a class="btn btn-chelya btn-sm" asp-controller="Usuarios" asp-action="Registro">Registrarse</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-chelya text-center py-4 mt-5">
        <div class="container">
            <p class="mb-1 font-elegant" style="font-size: 1.1rem; letter-spacing: 2px;">Chelaya Luxury</p>
            <p class="mb-0 small">&copy; @DateTime.Now.Year &mdash; Elegancia que transforma tu belleza natural</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
