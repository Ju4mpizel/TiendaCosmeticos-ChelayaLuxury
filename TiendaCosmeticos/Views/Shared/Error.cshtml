@{
    ViewData["Title"] = "Error";
}

<div class="container my-5 text-center" style="max-width: 600px;">
    <div class="card-elegant p-5">
        <div class="mb-4">
            <i class="bi bi-exclamation-triangle" style="font-size: 4rem; color: var(--gold-accent);"></i>
        </div>
        <h1 class="font-elegant text-danger mb-3">Algo no salió como esperábamos</h1>
        <p class="text-muted mb-4">
            Ocurrió un inconveniente procesando tu solicitud. No te preocupes, nuestro equipo ya está revisándolo.
        </p>
        <div class="pt-2">
            <a href="/" class="btn btn-chelya px-4"><i class="bi bi-house me-2"></i>Volver al Inicio</a>
        </div>
    </div>
</div>
