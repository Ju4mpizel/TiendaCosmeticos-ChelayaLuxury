@model TiendaCosmeticos.Models.Producto

<div class="container my-4" style="max-width: 550px;">
    <div class="card-elegant p-4">
        <h3 class="font-elegant mb-4 text-center"><i class="bi bi-plus-circle me-2" style="color: var(--rose-gold);"></i> Crear Producto</h3>

        <form asp-action="Create" method="post">
            <div class="mb-3">
                <label>Nombre</label>
                <input asp-for="Nombre" class="form-control form-chelya" required />
            </div>
            <div class="mb-3">
                <label>Categoría</label>
                <select asp-for="CategoriaId" asp-items="ViewBag.CategoriasDisponibles" class="form-select form-chelya" required>
                    <option value="">-- Selecciona una categoría --</option>
                </select>
            </div>
            <div class="row mb-3">
                <div class="col">
                    <label>Precio (USD)</label>
                    <input asp-for="Precio" type="number" step="0.01" class="form-control form-chelya" required />
                </div>
                <div class="col">
                    <label>Stock</label>
                    <input asp-for="Stock" type="number" class="form-control form-chelya" required />
                </div>
            </div>
            <div class="mb-3">
                <label>URL de la Imagen</label>
                <input asp-for="ImagenUrl" class="form-control form-chelya" placeholder="https://..." />
            </div>
            <div class="mb-4">
                <label>Descripción</label>
                <textarea asp-for="Descripcion" class="form-control form-chelya" rows="3"></textarea>
            </div>

            <div class="d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-chelya-outline"><i class="bi bi-arrow-left me-1"></i>Volver</a>
                <button type="submit" class="btn btn-chelya"><i class="bi bi-check-lg me-1"></i>Guardar</button>
            </div>
        </form>
    </div>
</div>
