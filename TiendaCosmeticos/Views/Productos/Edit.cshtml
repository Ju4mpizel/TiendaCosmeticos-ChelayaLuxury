@model TiendaCosmeticos.Models.Producto

<div class="container my-4" style="max-width: 600px;">
    <div class="card-elegant p-4">
        <h2 class="font-elegant mb-4"><i class="bi bi-pencil-square me-2" style="color: var(--rose-gold);"></i> Editar Producto</h2>
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="mb-3">
                <label asp-for="Nombre">Nombre</label>
                <input asp-for="Nombre" class="form-control form-chelya" required />
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Precio">Precio (USD)</label>
                    <input asp-for="Precio" class="form-control form-chelya" type="number" step="0.01" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Stock">Stock</label>
                    <input asp-for="Stock" class="form-control form-chelya" type="number" required />
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Descripcion">Descripción</label>
                <textarea asp-for="Descripcion" class="form-control form-chelya" rows="2"></textarea>
            </div>
            <div class="mb-3">
                <label asp-for="ImagenUrl">URL de la Imagen</label>
                <input asp-for="ImagenUrl" class="form-control form-chelya" />
            </div>
            <div class="mb-3">
                <label asp-for="CategoriaId">Categoría</label>
                <select asp-for="CategoriaId" class="form-select form-chelya" asp-items="ViewBag.CategoriasDisponibles" required></select>
            </div>
            <div class="mb-3 form-check form-switch">
                <input asp-for="Activo" class="form-check-input" type="checkbox" id="switchProd">
                <label class="form-check-label text-muted" for="switchProd">Disponible a la venta</label>
            </div>
            <div class="d-flex justify-content-between mt-4">
                <a href="/Productos/Index" class="btn btn-chelya-outline"><i class="bi bi-arrow-left me-1"></i>Cancelar</a>
                <button type="submit" class="btn btn-chelya px-4"><i class="bi bi-check-lg me-1"></i>Guardar Cambios</button>
            </div>
        </form>
    </div>
</div>
