@model TiendaCosmeticos.Models.Usuario

<div class="container my-4" style="max-width: 500px;">
    <div class="card-elegant p-4">
        <h2 class="font-elegant mb-4"><i class="bi bi-pencil-square me-2" style="color: var(--rose-gold);"></i> Modificar Perfil de Usuario</h2>
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="PasswordHash" />

            <div class="mb-3">
                <label asp-for="NombreCompleto">Nombre Completo</label>
                <input asp-for="NombreCompleto" class="form-control form-chelya" required />
            </div>
            <div class="mb-3">
                <label asp-for="Email">Correo Electrónico</label>
                <input asp-for="Email" class="form-control form-chelya" type="email" required />
            </div>
            <div class="mb-3">
                <label asp-for="RolId">Rol Asignado</label>
                <select asp-for="RolId" class="form-select form-chelya" asp-items="ViewBag.RolesDisponibles" required></select>
            </div>
            <div class="mb-3 form-check form-switch">
                <input asp-for="Activo" class="form-check-input" type="checkbox" id="switchUser">
                <label class="form-check-label text-muted" for="switchUser">Usuario Habilitado</label>
            </div>
            <div class="d-flex justify-content-between mt-4">
                <a href="/Usuarios/Index" class="btn btn-chelya-outline"><i class="bi bi-arrow-left me-1"></i>Cancelar</a>
                <button type="submit" class="btn btn-chelya px-4"><i class="bi bi-check-lg me-1"></i>Actualizar Usuario</button>
            </div>
        </form>
    </div>
</div>
