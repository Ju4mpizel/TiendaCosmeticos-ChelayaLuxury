@model TiendaCosmeticos.Models.Usuario

<div class="container my-5" style="max-width: 450px;">
    <div class="card-elegant p-4">
        <h3 class="font-elegant text-center mb-3"><i class="bi bi-person-plus me-2" style="color: var(--rose-gold);"></i>Únete a Chelaya</h3>

        <form asp-controller="Usuarios" asp-action="Registro" method="post">
            <div class="mb-3">
                <label>Nombre Completo</label>
                <input asp-for="NombreCompleto" class="form-control form-chelya" required />
            </div>
            <div class="mb-3">
                <label>Correo Electrónico</label>
                <input asp-for="Email" type="email" class="form-control form-chelya" required />
            </div>
            <div class="mb-4">
                <label>Crea tu Contraseña</label>
                <input asp-for="PasswordHash" type="password" class="form-control form-chelya" required />
            </div>
            <button type="submit" class="btn btn-chelya w-100 py-2"><i class="bi bi-check-lg me-2"></i>Registrarme</button>
        </form>
    </div>
</div>
