<div class="container my-5" style="max-width: 400px;">
    <div class="card-elegant p-4 text-center">
        <i class="bi bi-person-circle" style="font-size: 3rem; color: var(--rose-gold);"></i>
        <h2 class="font-elegant mb-1 mt-2" style="font-size: 1.6rem;">Ingresar</h2>
        <p class="text-muted small mb-4">Accede a tu cuenta Chelaya Luxury</p>

        @if (ViewBag.Error != null)
        {
            <div class="alert-chelya mb-3">@ViewBag.Error</div>
        }

        <form asp-controller="Login" asp-action="Ingresar" method="post">
            <div class="mb-3 text-start">
                <label>Correo Electrónico</label>
                <input type="email" name="correo" class="form-control form-chelya" required />
            </div>
            <div class="mb-4 text-start">
                <label>Contraseña</label>
                <input type="password" name="password" class="form-control form-chelya" required />
            </div>
            <button type="submit" class="btn btn-chelya w-100 py-2 mb-3"><i class="bi bi-box-arrow-in-right me-2"></i>Entrar</button>
        </form>
    </div>
</div>
