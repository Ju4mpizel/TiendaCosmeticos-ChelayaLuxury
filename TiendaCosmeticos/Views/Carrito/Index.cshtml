@model IEnumerable<TiendaCosmeticos.Models.CarritoItem>

<div class="container my-4" style="max-width: 800px;">
    <h2 class="font-elegant mb-4" style="font-size: 1.8rem;"><i class="bi bi-bag me-2" style="color: var(--rose-gold);"></i> Tu Carrito de Compras</h2>

    @if (!Model.Any())
    {
        <div class="text-center py-5 card-elegant p-5">
            <i class="bi bi-bag-x" style="font-size: 3rem; color: var(--rose-gold);"></i>
            <p class="text-muted mt-3 mb-3">Tu bolsa de compras está vacía.</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-chelya">Explorar Catálogo</a>
        </div>
    }
    else
    {
        <div class="card-elegant p-4">
            @foreach (var item in Model)
            {
                <div class="cart-item d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="font-elegant mb-1" style="font-size: 1rem;">@item.NombreProducto</h5>
                        <small class="text-muted">@item.Cantidad x @item.Precio.ToString("0.00") USD</small>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <span class="font-elegant" style="font-size: 1.1rem;">@item.Subtotal.ToString("0.00") USD</span>

                        <form asp-action="Eliminar" method="post" style="display:inline;">
                            <input type="hidden" name="productoId" value="@item.ProductoId" />
                            <button type="submit" class="btn btn-link text-danger p-0 border-0 text-decoration-none" style="font-size: 1.1rem;"><i class="bi bi-trash3"></i></button>
                        </form>
                    </div>
                </div>
            }

            <hr class="divider-elegant my-4" />

            <div class="total-section d-flex justify-content-between align-items-center">
                <span class="total-label">Total General</span>
                <span class="total-value">@ViewBag.TotalCarrito.ToString("0.00") USD</span>
            </div>

            <div class="text-end mt-4">
                <form asp-action="ConfirmarCompra" method="post">
                    <button type="submit" class="btn btn-chelya py-2 px-5"><i class="bi bi-credit-card me-2"></i>Proceder al Pago</button>
                </form>
            </div>
        </div>
    }
</div>
